datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ----------------- Enums -----------------

enum MembershipStatus {
  ACTIVE
  LEFT
}

enum ImportAnomalyStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ImportAnomalySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ImportAnomalyType {
  DUPLICATE_EXPENSE
  INVALID_DATE
  AMBIGUOUS_DATE
  MISSING_CURRENCY
  NEGATIVE_AMOUNT
  UNKNOWN_MEMBER
  FORMER_MEMBER
  SETTLEMENT_LOGGED_AS_EXPENSE
}

enum ImportBatchStatus {
  PENDING
  PARSED
  FAILED
}

// ----------------- Models -----------------

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  memberships       Membership[]
  paidExpenses      Expense[]            @relation("ExpensesPaid")
  createdExpenses   Expense[]            @relation("ExpensesCreated")
  expenseShares     ExpenseParticipant[]
  sentSettlements   Settlement[]         @relation("SettlementsSent")
  rcvdSettlements   Settlement[]         @relation("SettlementsReceived")
  importBatches     ImportBatch[]        @relation("ImportBatchesUploaded")

  @@map("users")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  memberships Membership[]
  expenses    Expense[]
  settlements Settlement[]
  importBatches ImportBatch[]

  @@map("groups")
}

model Membership {
  id        String           @id @default(uuid())
  groupId   String
  userId    String
  status    MembershipStatus @default(ACTIVE)
  joinedAt  DateTime         @default(now())
  leftAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Mapped Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("memberships")
}

model Expense {
  id          String   @id @default(uuid())
  groupId     String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  date        DateTime
  paidById    String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Mapped Relations
  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy       User                 @relation("ExpensesPaid", fields: [paidById], references: [id], onDelete: Restrict)
  createdBy    User                 @relation("ExpensesCreated", fields: [createdById], references: [id], onDelete: Restrict)
  participants ExpenseParticipant[]

  @@map("expenses")
}

model ExpenseParticipant {
  id        String   @id @default(uuid())
  expenseId String
  userId    String
  share     Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  // Mapped Relations
  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([expenseId, userId])
  @@map("expense_participants")
}

model Settlement {
  id        String   @id @default(uuid())
  groupId   String
  payerId   String
  payeeId   String
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("USD")
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Mapped Relations
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer User  @relation("SettlementsSent", fields: [payerId], references: [id], onDelete: Restrict)
  payee User  @relation("SettlementsReceived", fields: [payeeId], references: [id], onDelete: Restrict)

  @@map("settlements")
}

model ImportBatch {
  id           String            @id @default(uuid())
  fileName     String
  groupId      String?
  uploadTime   DateTime          @default(now())
  totalRows    Int
  status       ImportBatchStatus @default(PENDING)
  uploadedById String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Mapped Relations
  group      Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  uploadedBy User        @relation("ImportBatchesUploaded", fields: [uploadedById], references: [id], onDelete: Restrict)
  rows       ImportRow[]
  anomalies  ImportAnomaly[]

  @@index([groupId])
  @@index([uploadedById])
  @@index([status])
  @@map("import_batches")
}

model ImportRow {
  id            String    @id @default(uuid())
  importBatchId String
  rowNumber     Int
  data          Json
  correctedData Json?
  createdAt     DateTime  @default(now())

  // Mapped Relations
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([importBatchId, rowNumber])
  @@index([importBatchId])
  @@map("import_rows")
}

model ImportAnomaly {
  id              String                @id @default(uuid())
  importBatchId   String
  rowNumber       Int
  anomalyType     ImportAnomalyType
  severity        ImportAnomalySeverity
  description     String
  suggestedAction String
  status          ImportAnomalyStatus   @default(PENDING)
  rawContent      Json
  history         Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  // Mapped Relations
  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId])
  @@index([importBatchId, rowNumber])
  @@index([status])
  @@map("import_anomalies")
}
